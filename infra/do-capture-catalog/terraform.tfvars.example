project_name      = "Stoarama"
region            = "nyc3"
droplet_count     = 1
droplet_size      = "s-2vcpu-4gb"
instance_name_prefix = "si-capture-catalog"
ssh_key_name      = "stoarama-capture-catalog-key"
ssh_public_key    = "ssh-ed25519 AAAA..."
# ssh_key_fingerprint = "12:34:56:..."

repo_url          = "https://github.com/daydemir/stoarama.git"
repo_ref          = "main"
repo_clone_token  = ""

backend_api_url   = "https://your-stoarama-api.example.com"
backend_api_token = "replace-me"

capture_shared_capacity = 10

capture_catalog_sweep_execution_classes = "video_live,image_poll"
capture_catalog_sweep_batch_per_class   = 10
capture_catalog_sweep_max_streams    = 30
capture_catalog_sweep_duration       = "4m"
capture_catalog_sweep_idle_sec       = 20
capture_catalog_sweep_poll_timeout_sec = 20
capture_catalog_sweep_refresh_sec    = 5

capture_unsupported_threshold     = 8
capture_frame_queue_size          = 64
capture_frame_enqueue_timeout_sec = 3
capture_frame_writers             = 2

admin_cidrs = ["0.0.0.0/0", "::/0"]
