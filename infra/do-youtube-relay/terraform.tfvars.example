project_name  = "Stoarama"
region        = "nyc3"
droplet_count = 2
droplet_size  = "s-2vcpu-4gb"

instance_name_prefix = "si-yt-sink"
ssh_key_name         = "stoarama-youtube-relay-key"
ssh_public_key       = "ssh-ed25519 AAAA..."
# optional: set when reusing an existing key directly
# ssh_key_fingerprint = "12:34:56:..."
admin_cidrs          = ["0.0.0.0/0", "::/0"]

repo_url         = "https://github.com/daydemir/stoarama.git"
repo_ref         = "main"
repo_clone_token = ""

backend_api_url   = "https://stoarama-api.onrender.com"
backend_api_token = "replace-me"

youtube_relay_source_public_base_url = "https://relay-source.example.com/ytrelay"
youtube_relay_shared_token           = "replace-with-long-random-token"
youtube_relay_network_transport      = "wireguard"
youtube_relay_topology_id            = "do-youtube-relay-hub"
youtube_relay_hub_server_id          = "do-youtube-relay-hub"
youtube_relay_source_server_id       = "yt-relay-source-mini"
youtube_relay_wg_interface           = "wg0"
youtube_relay_wg_source_ip           = "10.77.0.2"
youtube_relay_wg_sink_cidr           = "10.77.0.0/24"
youtube_relay_wg_sink_offset         = 11

youtube_relay_sink_capacity             = 8
youtube_relay_heartbeat_sec             = 15
youtube_relay_lease_sec                 = 45
youtube_relay_refresh_sec               = 5
youtube_relay_unsupported_threshold     = 8
youtube_relay_frame_queue_size          = 64
youtube_relay_frame_enqueue_timeout_sec = 3
youtube_relay_frame_writers             = 2

extra_tags = ["fleet:youtube-relay"]
