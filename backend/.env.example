# Required
DATABASE_URL=postgres://social_isolation:social_isolation@localhost:54329/social_isolation?sslmode=disable
API_TOKEN=replace-me

# Migrations
AUTO_MIGRATE=true
MIGRATION_DIR=../infra/sql/migrations
PORT=8080

# R2 (Cloudflare)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
# Optional override (useful for local MinIO)
R2_ENDPOINT=

# Signed URL TTLs
R2_SIGN_GET_TTL=10m
R2_SIGN_PUT_TTL=15m

# Capture worker
CAPTURE_TICK_SEC=5
CAPTURE_LEASE_SEC=90
WORKER_ID=capture-worker-1
